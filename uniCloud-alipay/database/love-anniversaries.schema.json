{
	"bsonType": "object",
	"required": [
		"couple_id",
		"title",
		"date_type",
		"date_value",
		"repeat_type"
	],
	"permission": {
		"read": false,
		"create": false,
		"update": false,
		"delete": false
	},
	"properties": {
		"_id": {
			"description": "纪念日ID，系统自动生成"
		},
		"couple_id": {
			"bsonType": "string",
			"title": "情侣关系ID"
		},
		"creator_uid": {
			"bsonType": "string",
			"title": "创建人用户ID"
		},
		"title": {
			"bsonType": "string",
			"title": "纪念日标题"
		},
		"date_type": {
			"bsonType": "string",
			"title": "日期类型",
			"description": "solar 公历 / lunar 农历",
			"defaultValue": "solar"
		},
		"date_value": {
			"bsonType": "string",
			"title": "日期值",
			"description": "格式 YYYY-MM-DD"
		},
		"solar_date_value": {
			"bsonType": "string",
			"title": "公历日期值",
			"description": "格式 YYYY-MM-DD，与 date_value 保持一致"
		},
		"lunar_date_value": {
			"bsonType": "string",
			"title": "农历日期值",
			"description": "格式示例：2026年正月初一"
		},
		"date_timestamp": {
			"bsonType": "long",
			"title": "日期时间戳",
			"description": "所选日期对应的本地零点时间戳，毫秒"
		},
		"next_date_timestamp": {
			"bsonType": "long",
			"title": "下一次日期时间戳",
			"description": "用于列表按距离今天最近排序的派生字段，毫秒"
		},
		"next_date_value": {
			"bsonType": "string",
			"title": "下一次日期",
			"description": "下一次发生日期，格式 YYYY-MM-DD"
		},
		"next_date_refresh_date": {
			"bsonType": "string",
			"title": "下一次日期刷新日期",
			"description": "派生字段刷新日期，格式 YYYY-MM-DD"
		},
		"repeat_type": {
			"bsonType": "string",
			"title": "重复方式",
			"description": "none / weekly / monthly / yearly",
			"defaultValue": "yearly"
		},
		"background_type": {
			"bsonType": "string",
			"title": "背景类型",
			"description": "image / color",
			"defaultValue": "color"
		},
		"background_image": {
			"bsonType": "object",
			"title": "背景图片",
			"properties": {
				"url": {
					"bsonType": "string"
				},
				"file_id": {
					"bsonType": "string"
				}
			}
		},
		"background_color": {
			"bsonType": "string",
			"title": "背景色",
			"defaultValue": "#EC7558"
		},
		"font_color": {
			"bsonType": "string",
			"title": "字体色",
			"defaultValue": "#FFFFFF"
		},
		"mask_enabled": {
			"bsonType": "bool",
			"title": "是否启用遮罩",
			"defaultValue": true
		},
		"mask_color": {
			"bsonType": "string",
			"title": "遮罩颜色",
			"defaultValue": "#000000"
		},
		"mask_opacity": {
			"bsonType": "double",
			"title": "遮罩透明度",
			"defaultValue": 0.35
		},
		"is_deleted": {
			"bsonType": "bool",
			"title": "是否删除",
			"defaultValue": false
		},
		"create_time": {
			"bsonType": "long",
			"title": "创建时间"
		},
		"update_time": {
			"bsonType": "long",
			"title": "更新时间"
		}
	}
}
